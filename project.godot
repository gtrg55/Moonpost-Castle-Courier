; Moonpost: Castle Courier — portfolio vertical slice
config_version=5

[application]

config/name="Moonpost: Castle Courier"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[input]

accelerate={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":87), Object(InputEventKey,"physical_keycode":4194320)]
}
brake={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":83), Object(InputEventKey,"physical_keycode":4194322)]
}
turn_left={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":65), Object(InputEventKey,"physical_keycode":4194319)]
}
turn_right={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":68), Object(InputEventKey,"physical_keycode":4194321)]
}
ascend={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":32)]
}
descend={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":4194323), Object(InputEventKey,"physical_keycode":67)]
}
toggle_mouse={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":4194305)]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/default_filters/use_nearest_mipmap_filter=false
environment/defaults/default_clear_color=Color(0.035, 0.028, 0.075, 1)
