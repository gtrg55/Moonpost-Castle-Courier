[sub_resource type="Shader" id="Shader_vignette"]
code = "shader_type canvas_item;\nrender_mode unshaded;\n\nuniform float strength : hint_range(0.0, 1.0) = 0.72;\nuniform float softness : hint_range(0.05, 0.8) = 0.34;\n\nvoid fragment() {\n\tvec2 edge_distance = abs(UV - vec2(0.5)) * 2.0;\n\tfloat rounded_edge = length(edge_distance * vec2(0.82, 1.0));\n\tfloat border_edge = max(edge_distance.x * 0.88, edge_distance.y);\n\tfloat vignette = smoothstep(1.0 - softness, 1.05, max(rounded_edge, border_edge));\n\tCOLOR = vec4(0.012, 0.006, 0.025, vignette * strength);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vignette"]
shader = SubResource("Shader_vignette")
shader_parameter/strength = 0.72
shader_parameter/softness = 0.34

